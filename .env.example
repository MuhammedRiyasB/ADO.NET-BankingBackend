# ============================================================
# BankingBackend — Required Environment Variables
# ============================================================
# Copy this file, rename to .env, and fill in your values.
# Then set these in your system environment or launch profile.
# ============================================================

# SQL Server connection string
BANKING_DB_CONNECTION=Server=(localdb)\MSSQLLocalDB;Database=BankingBackendDb_Dev;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True

# JWT signing key (minimum 32 characters)
BANKING_JWT_SIGNING_KEY=YourSuperSecretKeyThatIsAtLeast32CharsLong!

# Initial admin user password (used only on first run when no users exist)
BANKING_ADMIN_PASSWORD=Admin@12345

# Prefer running migrations explicitly in deployment automation:
# dotnet run --project src/Banking.API/Banking.API.csproj -- --migrate
BANKING_RUN_MIGRATIONS=false
